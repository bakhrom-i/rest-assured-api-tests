<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="API Suite" parallel="methods" thread-count="4">
    <test name="auth">
        <groups>
            <run><include name="auth"/></run>
        </groups>
        <packages><package name="com.portfolio.api.tests"/></packages>
    </test>
    <test name="crud">
        <groups>
            <run><include name="crud"/></run>
        </groups>
        <packages><package name="com.portfolio.api.tests"/></packages>
    </test>
</suite>
